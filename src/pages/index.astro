---
import '../styles/global.css';
import Guestbook from '../components/Guestbook.tsx';
import Confetti from '../components/Confetti.tsx';
import HitCounter from '../components/HitCounter.astro';
import AboutMe from '../components/AboutMe.astro';
import Projects from '../components/Projects.astro';
import Socials from '../components/Socials.astro';
import Footer from '../components/Footer.astro';
import fakeSitesData from '../data/fakeSites.json';

// Media imports
import favicon from '../assets/media/favicon.ico';
import Webring from '../components/Webring';
---
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Silly Boats ~ Welcome!</title>
		<link rel="icon" type="image/x-icon" href={favicon} />
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet" />
	</head>
	<body>
	<div class="retro-bg" aria-hidden="true"></div>
	<div class="container py-4 position-relative site-wrap">
		<header class="text-center mb-4 retro-header">
			<p class="splashText mb-1">~ Horsing around since 2001 ~</p>
			<h1 class="site-title mb-2">
				<span class="title-graphic" aria-hidden="true">✦</span>
				Yannick's Silly Stables
				<span class="title-graphic" aria-hidden="true">✦</span>
			</h1>
			<p class="tagline mb-0">Code Wizard · Horse enthusiast · Friend to all browsers</p>
		</header>
		<p id="site-hint" class="site-hint small text-center mb-2 d-none" role="status"></p>
		<HitCounter />
		<div class="row g-4">
			<div class="col-lg-8">
				<AboutMe />
				<Projects />
			</div>
			<aside class="col-lg-4">
				<Guestbook client:load />
				<Socials />
				<Webring client:load sites={fakeSitesData.sites} />
				<Confetti client:load />
			</aside>
		</div>
		<Footer />
	</div>
	<div id="confetti-layer" class="confetti-layer" aria-hidden="true"></div>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
	</body>
</html>
